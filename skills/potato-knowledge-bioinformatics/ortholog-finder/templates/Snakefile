from pathlib import Path

configfile: "config.yaml"

ENV_PREFIX = config.get("env_prefix", "")
SCRIPTS_DIR = config.get("scripts_dir", "scripts")
A = config["species"]["a"]
B = config["species"]["b"]
M = config["mcscan"]

AP = A["prefix"]
BP = B["prefix"]
PAIR = f"{AP}.{BP}"
DBTYPE = M.get("dbtype", "prot")
SUFFIX = "pep" if DBTYPE == "prot" else "cds"
THREADS = int(M.get("cpus", 16))
CSCORE = str(M.get("cscore", 0.7))

ANCHOR_CFG = config.get("anchor_mapping", {}) or {}
USE_LIFTED_ANCHORS = bool(ANCHOR_CFG.get("use_lifted", False))
ANCHOR_SOURCE_LABEL = ANCHOR_CFG.get("synteny_label", "synteny")
FALLBACK_ENABLED = bool(ANCHOR_CFG.get("fallback_enabled", True))
FALLBACK_LABEL = ANCHOR_CFG.get("fallback_label", "")
FALLBACK_MIN_IDENTITY = float(ANCHOR_CFG.get("fallback_min_identity", 90.0))
ALLOW_CONTAINMENT_MATCH = bool(ANCHOR_CFG.get("allow_containment_match", True))

NO_SUFFIX_CFG = config.get("no_suffix", {}) or {}
NO_SUFFIX_ENABLED = bool(NO_SUFFIX_CFG.get("enabled", True))
NO_SUFFIX_OUTPUT = NO_SUFFIX_CFG.get("output") or "results/final_mapped_gene_anchor.no_suffix.txt"
NO_SUFFIX_COLUMN = int(NO_SUFFIX_CFG.get("column", 2))
NO_SUFFIX_MODE = NO_SUFFIX_CFG.get("mode", "numeric_suffix")
NO_SUFFIX_REGEX = NO_SUFFIX_CFG.get("regex", r"\.[0-9]+$")

ID_CHECK_CFG = config.get("id_check", {}) or {}
GENE_ID_CFG = config.get("gene_id", {}) or {}

GENE_ID_GFFS = GENE_ID_CFG.get("gffs") or [A["gff3"]]
GENE_ID_OUTPUT = "results/gene_ids.txt"
GENE_TX_OUTPUT = "results/gene_to_transcript.tsv"

LIFTED_ANCHORS = f"results/{PAIR}.lifted.anchors"
ANCHORS_FILE = f"results/{PAIR}.anchors"
ANCHORS_FOR_MAPPING = LIFTED_ANCHORS if USE_LIFTED_ANCHORS else ANCHORS_FILE
FILTERED = f"results/{PAIR}.last.filtered"
FINAL_OUTPUT = "results/final_mapped_gene_anchor.txt"

SCRIPT_CHECK_IDS = str(Path(SCRIPTS_DIR) / "check_bed_fasta_ids.py")
SCRIPT_EXTRACT_GENES = str(Path(SCRIPTS_DIR) / "extract_gene_ids.py")
SCRIPT_MAP_ORTHOLOGS = str(Path(SCRIPTS_DIR) / "map_anchor_orthologs.py")
SCRIPT_REMOVE_SUFFIX = str(Path(SCRIPTS_DIR) / "remove_mapping_suffix.py")

FINAL_OUTPUTS = [
    "results/id_check.tsv",
    ANCHORS_FILE,
    LIFTED_ANCHORS,
    FILTERED,
    FINAL_OUTPUT,
    GENE_ID_OUTPUT,
    GENE_TX_OUTPUT,
]
if NO_SUFFIX_ENABLED:
    FINAL_OUTPUTS.append(NO_SUFFIX_OUTPUT)

if ENV_PREFIX:
    shell.prefix(f"export PATH={ENV_PREFIX}/bin:$PATH; set -euo pipefail; ")
else:
    shell.prefix("set -euo pipefail; ")


rule all:
    input:
        FINAL_OUTPUTS


rule mkdirs:
    output:
        touch("work/.dirs.done")
    shell:
        "mkdir -p work results logs && touch {output:q}"


rule gff_to_bed_a:
    input:
        rules.mkdirs.output,
        gff=A["gff3"]
    output:
        f"work/{AP}.bed"
    log:
        f"logs/{AP}.gff_to_bed.log"
    params:
        gff_type=A.get("gff_type", "mRNA"),
        gff_key=A.get("gff_key", "ID")
    shell:
        "python -m jcvi.formats.gff bed --type={params.gff_type:q} --key={params.gff_key:q} {input.gff:q} -o {output:q} > {log:q} 2>&1"


rule gff_to_bed_b:
    input:
        rules.mkdirs.output,
        gff=B["gff3"]
    output:
        f"work/{BP}.bed"
    log:
        f"logs/{BP}.gff_to_bed.log"
    params:
        gff_type=B.get("gff_type", "mRNA"),
        gff_key=B.get("gff_key", "ID")
    shell:
        "python -m jcvi.formats.gff bed --type={params.gff_type:q} --key={params.gff_key:q} {input.gff:q} -o {output:q} > {log:q} 2>&1"


rule link_fasta_a:
    input:
        rules.mkdirs.output,
        fasta=A["fasta"]
    output:
        f"work/{AP}.{SUFFIX}"
    shell:
        "ln -sf $(readlink -f {input.fasta:q}) {output:q}"


rule link_fasta_b:
    input:
        rules.mkdirs.output,
        fasta=B["fasta"]
    output:
        f"work/{BP}.{SUFFIX}"
    shell:
        "ln -sf $(readlink -f {input.fasta:q}) {output:q}"


rule check_ids:
    input:
        script=SCRIPT_CHECK_IDS,
        bed_a=f"work/{AP}.bed",
        fa_a=f"work/{AP}.{SUFFIX}",
        bed_b=f"work/{BP}.bed",
        fa_b=f"work/{BP}.{SUFFIX}"
    output:
        "results/id_check.tsv"
    params:
        ap=AP,
        bp=BP,
        fail_on_fasta_extra="--fail-on-fasta-extra" if ID_CHECK_CFG.get("fail_on_fasta_extra", False) else ""
    shell:
        """
        python {input.script:q} \
          --dataset {params.ap:q} {input.bed_a:q} {input.fa_a:q} \
          --dataset {params.bp:q} {input.bed_b:q} {input.fa_b:q} \
          {params.fail_on_fasta_extra} > {output:q}
        """


rule mcscan_with_anchors:
    """Run MCScan and keep .last, .last.filtered, .anchors, and .lifted.anchors."""
    input:
        check="results/id_check.tsv",
        bed_a=f"work/{AP}.bed",
        fa_a=f"work/{AP}.{SUFFIX}",
        bed_b=f"work/{BP}.bed",
        fa_b=f"work/{BP}.{SUFFIX}"
    output:
        last=f"results/{PAIR}.last",
        filtered=FILTERED,
        anchors=ANCHORS_FILE,
        lifted=LIFTED_ANCHORS,
    log:
        "logs/mcscan_ortholog.log"
    threads: THREADS
    params:
        dbtype=DBTYPE,
        align=M.get("align_soft", "last"),
        cscore=CSCORE,
        no_strip="--no_strip_names" if M.get("no_strip_names", True) else "",
        dot="--no_dotplot" if M.get("no_dotplot", True) else "",
    shell:
        r"""
        tmp=$(mktemp -d work/mcscan_tmp.XXXXXX)
        ln -sf $(readlink -f {input.bed_a:q}) $tmp/{AP}.bed
        ln -sf $(readlink -f {input.fa_a:q}) $tmp/{AP}.{SUFFIX}
        ln -sf $(readlink -f {input.bed_b:q}) $tmp/{BP}.bed
        ln -sf $(readlink -f {input.fa_b:q}) $tmp/{BP}.{SUFFIX}
        cd $tmp
        python -m jcvi.compara.catalog ortholog {AP:q} {BP:q} \
          --dbtype={params.dbtype:q} \
          --align_soft={params.align:q} \
          {params.no_strip} \
          --cscore={params.cscore:q} \
          --cpus={threads} \
          {params.dot} > ../../{log:q} 2>&1
        cd ../..
        mv -f $tmp/{PAIR}.last {output.last:q}
        mv -f $tmp/{PAIR}.last.filtered {output.filtered:q}
        mv -f $tmp/{PAIR}.anchors {output.anchors:q}
        mv -f $tmp/{PAIR}.lifted.anchors {output.lifted:q}
        rm -rf $tmp
        """


rule extract_gene_ids:
    input:
        script=SCRIPT_EXTRACT_GENES,
        gffs=GENE_ID_GFFS,
        prereqs=[ANCHORS_FILE, FILTERED]
    output:
        gene_ids=GENE_ID_OUTPUT,
        gene_tx=GENE_TX_OUTPUT
    log:
        "logs/extract_gene_ids.log"
    params:
        gene_type=GENE_ID_CFG.get("gene_type", "gene"),
        transcript_types=",".join(GENE_ID_CFG.get("transcript_types", ["mRNA", "transcript"])),
        gene_id_key=GENE_ID_CFG.get("gene_id_key", "ID"),
        transcript_id_key=GENE_ID_CFG.get("transcript_id_key", "ID"),
        parent_key=GENE_ID_CFG.get("parent_key", "Parent")
    shell:
        """
        python {input.script:q} \
          --gene-ids-output {output.gene_ids:q} \
          --gene-transcript-output {output.gene_tx:q} \
          --log {log:q} \
          --gene-type {params.gene_type:q} \
          --transcript-types {params.transcript_types:q} \
          --gene-id-key {params.gene_id_key:q} \
          --transcript-id-key {params.transcript_id_key:q} \
          --parent-key {params.parent_key:q} \
          {input.gffs:q}
        """


rule final_mapped_gene_anchor:
    input:
        script=SCRIPT_MAP_ORTHOLOGS,
        gene_ids=GENE_ID_OUTPUT,
        gene_tx=GENE_TX_OUTPUT,
        anchors=ANCHORS_FOR_MAPPING,
        filtered=FILTERED
    output:
        FINAL_OUTPUT
    log:
        "logs/final_mapped_gene_anchor.log"
    params:
        synteny_label=ANCHOR_SOURCE_LABEL,
        fallback_enabled="--fallback-enabled" if FALLBACK_ENABLED else "--no-fallback",
        fallback_label_arg=["--fallback-label", FALLBACK_LABEL] if FALLBACK_LABEL else [],
        fallback_min_identity=FALLBACK_MIN_IDENTITY,
        allow_containment="--allow-containment-match" if ALLOW_CONTAINMENT_MATCH else "--no-containment-match"
    shell:
        """
        python {input.script:q} \
          --gene-ids {input.gene_ids:q} \
          --gene-transcripts {input.gene_tx:q} \
          --anchors {input.anchors:q} \
          --filtered {input.filtered:q} \
          --output {output:q} \
          --log {log:q} \
          --synteny-label {params.synteny_label:q} \
          {params.fallback_label_arg:q} \
          --fallback-min-identity {params.fallback_min_identity} \
          {params.fallback_enabled} \
          {params.allow_containment}
        """


rule remove_mapped_gene_suffix:
    input:
        script=SCRIPT_REMOVE_SUFFIX,
        mapping=FINAL_OUTPUT
    output:
        NO_SUFFIX_OUTPUT
    log:
        "logs/remove_mapped_gene_suffix.log"
    params:
        column=NO_SUFFIX_COLUMN,
        mode=NO_SUFFIX_MODE,
        regex=NO_SUFFIX_REGEX
    shell:
        """
        python {input.script:q} \
          --input {input.mapping:q} \
          --output {output:q} \
          --log {log:q} \
          --column {params.column} \
          --mode {params.mode:q} \
          --regex {params.regex:q}
        """
